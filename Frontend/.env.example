# Base path for the versioned REST API (proxied through Vite in dev, or your
# reverse proxy / API gateway in production).
VITE_API_BASE_URL=/api/v1

# Root of the backend (used for unversioned endpoints like /health).
# Leave empty to use the same origin as the frontend (recommended with the
# Vite dev proxy or an Nginx reverse proxy in production).
VITE_API_ROOT=

# Target the Vite dev server proxies /api requests to.
VITE_API_PROXY_TARGET=http://localhost:8000

# Optional: realtime updates. The current backend does not expose a
# Socket.IO gateway yet, so this stays "false" and the app polls
# GET /search/{id} instead. Flip to "true" once a websocket gateway exists.
VITE_ENABLE_WEBSOCKET=false
VITE_WS_URL=
